# Get these from https://dev.reclaimprotocol.org/ — sign up, create an app,
# copy the IDs from the dashboard. APP_SECRET must not ship in a browser
# bundle — it lives only in this backend.

RECLAIM_APP_ID=0x...your-app-id
RECLAIM_APP_SECRET=0x...your-app-secret
RECLAIM_DEFAULT_PROVIDER_ID=...your-github-provider-id

# Optional. Default 4001.
PORT=4001

# Optional. Comma-separated list, or "*" for any origin (dev only).
# In production, set to e.g. "https://kvkthecreator.github.io"
ALLOWED_ORIGINS=*
